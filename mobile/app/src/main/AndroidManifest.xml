            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:name=".ui.cars.CarDetailsActivity" android:exported="false" android:label="@string/title_car_details" android:parentActivityName=".ui.cars.CarsActivity"/>
